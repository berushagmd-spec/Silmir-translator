# Токен взять у @BotFather
8848627122:AAEB_v0fEALcNm31V2C3pRtBV4fGzYJciO4

# Можно указать zip или папку. Несколько путей — через запятую.
# Примеры:
# SILMIR_DATA_PATHS=data/Сильмир.zip
# SILMIR_DATA_PATHS=data/archive,archive,словарр
SILMIR_DATA_PATHS=data/Сильмир.zip,data/archive,archive,словарр

# Где хранить индекс словаря. Создаётся автоматически при первом запуске.
SILMIR_INDEX_PATH=data/silmir.sqlite3

# 1 — пересобрать индекс при старте, 0 — использовать готовый.
SILMIR_REBUILD_INDEX=0
